{
  "defaultLayout": "force",
  "nodeSize": 7,
  "showLabels": false,
  "metadataFields": ["tags", "category"],
  "edgeFields": ["tags", "category"],
  "colorField": "category",
  "groupField": "category",
  "ontology": {
    "inheritanceFields": ["parent", "extends", "up"],
    "aggregationFields": ["contains", "parts", "has"],
    "similarFields": ["similar", "related"],
    "useTagHierarchy": true,
    "customMappings": {}
  },
  "showSimilar": false,
  "directionalGravityRules": [],
  "enclosureMinRatio": 0.03,
  "groupPresets": [
    {
      "condition": { "tagDisplay": "enclosure" },
      "groups": [],
      "commonQueries": [{ "query": "backlinks:*", "recursive": false }]
    }
  ],
  "defaultSortRules": [
    { "key": "degree", "order": "desc" }
  ],
  "defaultClusterGroupRules": [
    { "groupBy": "backlinks", "recursive": false }
  ],
  "defaultNodeRules": [],
  "defaultClusterArrangement": "tree",
  "defaultClusterNodeSpacing": 1.2,
  "defaultClusterGroupScale": 4.0,
  "defaultClusterGroupSpacing": 3.5,
  "settingsJsonPath": ""
}
