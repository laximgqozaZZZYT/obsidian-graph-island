{
  "layout": "force",
  "showTags": false,
  "showAttachments": false,
  "existingOnly": true,
  "showOrphans": false,
  "showArrows": false,
  "textFadeThreshold": 0.5,
  "nodeSize": 4,
  "scaleByDegree": true,
  "centerForce": 0.001,
  "repelForce": 100,
  "linkForce": 0.03,
  "linkDistance": 70,
  "groups": [],
  "searchQuery": "path:classic-arthurian* OR path:classic-divine-comedy*",
  "colorEdgesByRelation": true,
  "colorNodesByCategory": true,
  "showInheritance": true,
  "showAggregation": true,
  "showTagNodes": false,
  "tagDisplay": "node",
  "showSimilar": true,
  "showSibling": true,
  "showSequence": true,
  "showLinks": true,
  "showTagEdges": false,
  "showCategoryEdges": true,
  "showSemanticEdges": true,
  "enclosureSpacing": 1.5,
  "directionalGravityRules": [
    {"filter": "path:classic-arthurian*",      "direction": 3.14159, "strength": 0.90},
    {"filter": "path:classic-divine-comedy*",  "direction": 0,       "strength": 0.90}
  ],
  "hoverHops": 2,
  "commonQueries": [],
  "clusterGroupRules": [{"groupBy": "folder:?", "recursive": false}],
  "clusterArrangement": "tree",
  "clusterNodeSpacing": 3.0,
  "clusterGroupScale": 2.0,
  "clusterGroupSpacing": 2.0,
  "fadeEdgesByDegree": false,
  "edgeBundleStrength": 1.0,
  "sortRules": [],
  "nodeRules": [],
  "nodeShapeRules": [
    {"match": "category", "category": "protagonist", "shape": "hexagon"},
    {"match": "category", "category": "guide", "shape": "diamond"},
    {"match": "default", "shape": "circle"}
  ],
  "timelineKey": "start-date",
  "showEdgeLabels": false,
  "showMinimap": false,
  "groupBy": "folder:?",
  "groupByRules": null,
  "groupMinSize": 2,
  "groupFilter": "",
  "collapsedGroups": [],
  "activeTab": "layout",
  "heatmapMode": false,
  "showDotGrid": true,
  "autoFit": false,
  "showGuideLines": false,
  "guideLineMode": "shared",
  "showGroupGrid": false,
  "showDurationBars": false,
  "timelineEndKey": "end-date",
  "timelineOrderFields": "",
  "timelineRangeMin": 0,
  "timelineRangeMax": 1,
  "clusterArrangement": "custom",
  "coordinateLayout": {
    "system": "cartesian",
    "axis1": {
      "source": { "kind": "index" },
      "transform": { "kind": "expression", "expr": "(i/n)^d*(cos(pi/k)/cos(i*2.39996%(2*pi/k)-pi/k))*cos(i*2.39996)", "scale": 1 }
    },
    "axis2": {
      "source": { "kind": "index" },
      "transform": { "kind": "expression", "expr": "(i/n)^d*(cos(pi/k)/cos(i*2.39996%(2*pi/k)-pi/k))*sin(i*2.39996)", "scale": 1 }
    },
    "perGroup": true,
    "constants": { "k": 6, "d": 0.5 }
  },
  "dataviewQuery": ""
}
