{
  "layout": "force",
  "showTags": false,
  "showAttachments": false,
  "existingOnly": true,
  "showOrphans": false,
  "showArrows": true,
  "textFadeThreshold": 0.4,
  "nodeSize": 4,
  "scaleByDegree": false,
  "centerForce": 0.001,
  "repelForce": 60,
  "linkForce": 0.02,
  "linkDistance": 50,
  "groups": [],
  "searchQuery": "path:classic-arthurian*",
  "colorEdgesByRelation": true,
  "colorNodesByCategory": true,
  "showInheritance": false,
  "showAggregation": false,
  "showTagNodes": false,
  "tagDisplay": "node",
  "showSimilar": false,
  "showSibling": false,
  "showSequence": true,
  "showLinks": true,
  "showTagEdges": false,
  "showCategoryEdges": true,
  "showSemanticEdges": false,
  "enclosureSpacing": 1.5,
  "directionalGravityRules": [],
  "hoverHops": 2,
  "commonQueries": [],
  "clusterGroupRules": [
    {
      "groupBy": "category:?",
      "recursive": false
    }
  ],
  "clusterArrangement": "timeline",
  "clusterNodeSpacing": 2.0,
  "clusterGroupScale": 2.0,
  "clusterGroupSpacing": 2.0,
  "fadeEdgesByDegree": false,
  "edgeBundleStrength": 0.5,
  "sortRules": [],
  "nodeRules": [],
  "nodeShapeRules": [
    {
      "match": "category",
      "category": "protagonist",
      "shape": "hexagon"
    },
    {
      "match": "default",
      "shape": "circle"
    }
  ],
  "timelineKey": "story_order",
  "showEdgeLabels": false,
  "showMinimap": true,
  "groupBy": "category:?",
  "groupByRules": null,
  "groupMinSize": 2,
  "groupFilter": "",
  "collapsedGroups": [],
  "activeTab": "layout",
  "heatmapMode": false,
  "showDotGrid": false,
  "autoFit": false,
  "showGuideLines": true,
  "guideLineMode": "per-group",
  "showGroupGrid": true,
  "showDurationBars": true,
  "timelineEndKey": "end_order",
  "timelineOrderFields": "next,prev,parent_id,story_order",
  "timelineRangeMin": 0,
  "timelineRangeMax": 1,
  "gridTableMode": true,
  "gridShowHeaders": true,
  "gridCellShading": false,
  "gridStyle": "lines",
  "coordinateLayout": {
    "system": "cartesian",
    "axis1": { "source": { "kind": "property", "key": "story_order" }, "transform": { "kind": "date-to-index" } },
    "axis2": { "source": { "kind": "index" }, "transform": { "kind": "stack-avoid" } },
    "perGroup": true,
    "grid": {
      "axis1Grid": {
        "positions": { "kind": "count", "n": 8 },
        "shape": { "kind": "line" },
        "ticks": { "show": true, "labels": { "kind": "auto" } }
      },
      "style": "lines"
    }
  },
  "dataviewQuery": ""
