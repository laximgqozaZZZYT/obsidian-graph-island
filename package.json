{
  "name": "obsidian-graph-island",
  "version": "0.1.0",
  "description": "Graph Island — Multiple graph visualization layouts for Obsidian",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs watch",
    "build": "node esbuild.config.mjs production",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npx playwright test --config=e2e/obsidian-e2e.config.ts",
    "test:e2e:harness": "npx playwright test --config=playwright.config.ts"
  },
  "keywords": [
    "obsidian",
    "graph",
    "visualization"
  ],
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/d3-selection": "^3.0.0",
    "@types/d3-shape": "^3.0.0",
    "@types/d3-zoom": "^3.0.0",
    "@types/node": "^20.11.0",
    "esbuild": "^0.24.0",
    "obsidian": "latest",
    "typescript": "^5.5.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@types/d3-force": "^3.0.10",
    "d3-force": "^3.0.0",
    "d3-selection": "^3.0.0",
    "d3-shape": "^3.1.0",
    "d3-zoom": "^3.0.0",
    "pixi.js": "^7.4.3"
  }
}
