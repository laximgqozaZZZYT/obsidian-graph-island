{
  "defaultLayout": "force",
  "nodeSize": 8,
  "showLabels": true,
  "metadataFields": ["tags", "category", "characters", "locations"],
  "edgeFields": ["tags", "category"],
  "colorField": "category",
  "groupField": "category",
  "ontology": {
    "inheritanceFields": ["parent", "extends", "up"],
    "aggregationFields": ["contains", "parts", "has"],
    "similarFields": ["similar", "related"],
    "useTagHierarchy": true,
    "customMappings": {}
  },
  "showSimilar": false,
  "directionalGravityRules": [
    { "filter": "tag:character", "direction": "top", "strength": 0.2 },
    { "filter": "tag:location",  "direction": "bottom", "strength": 0.2 },
    { "filter": "tag:scene",     "direction": "right", "strength": 0.15 },
    { "filter": "tag:item",      "direction": "left", "strength": 0.15 }
  ],
  "enclosureMinRatio": 0.03,
  "groupPresets": [
    {
      "condition": { "tagDisplay": "enclosure" },
      "groups": [],
      "commonQueries": [{ "query": "tag:*", "recursive": false }]
    },
    {
      "condition": { "layout": "force" },
      "groups": [
        { "expression": { "type": "leaf", "field": "tag", "value": "character" }, "color": "#ec4899" },
        { "expression": { "type": "leaf", "field": "tag", "value": "location" },  "color": "#10b981" },
        { "expression": { "type": "leaf", "field": "tag", "value": "scene" },     "color": "#f59e0b" },
        { "expression": { "type": "leaf", "field": "tag", "value": "item" },      "color": "#6366f1" }
      ]
    }
  ],
  "defaultSortRules": [{ "key": "degree", "order": "desc" }],
  "defaultClusterGroupRules": [{ "groupBy": "tag", "recursive": false }],
  "defaultNodeRules": [],
  "settingsJsonPath": ""
}
